# Model Regression Detector — Environment Variables
# Copy this to .env and fill in your values.

# Required: OpenAI API key for running the classifier
OPENAI_API_KEY=sk-your-key-here

# Optional: Override the prompts directory (defaults to ./prompts)
# MRD_PROMPTS_DIR=/path/to/prompts

# Optional: Slack webhook URL for alerts (Phase 4)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
